; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[android]

permissions=PackedStringArray("android.permission.RECORD_AUDIO")

[application]

config/name="Азбука"
config/description="Russian alphabet learning game"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

Global="*res://scripts/global.gd"
AudioManager="*res://scripts/audio_manager.gd"
ThemeManager="*res://scripts/theme_manager.gd"
ProgressManager="*res://scripts/progress_manager.gd"
AlphabetData="*res://scripts/alphabet_data.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/initial_width=540
window/size/initial_height=960

[ios]

permissions=PackedStringArray("Microphone")

[rendering]

renderer/rendering_method="gl_compatibility"
